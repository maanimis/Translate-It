{
  "name": "translate-it",
  "version": "1.10.0",
  "type": "module",
  "description": "Smart Translation Assistant",
  "scripts": {
    "build": "node scripts/build/build-all.mjs --parallel",
    "build:sequential": "node scripts/build/build-all.mjs",
    "build:chrome": "node scripts/build/build-chrome.mjs",
    "build:firefox": "node scripts/build/build-firefox.mjs",
    "build:mobile": "node scripts/build/build-all.mjs --mobile --parallel",
    "build:chrome:mobile": "node scripts/build/build-chrome.mjs --mobile",
    "build:firefox:mobile": "node scripts/build/build-firefox.mjs --mobile",
    "watch:chrome": "cross-env NODE_ENV=development VITE_WATCH_MODE=true vite build --config config/vite/vite.config.chrome.js --watch",
    "watch:chrome:mobile": "cross-env IS_MOBILE=true NODE_ENV=development VITE_WATCH_MODE=true vite build --config config/vite/vite.config.chrome.js --watch",
    "watch:firefox": "cross-env NODE_ENV=development VITE_WATCH_MODE=true vite build --config config/vite/vite.config.firefox.js --watch",
    "watch:firefox:mobile": "cross-env IS_MOBILE=true NODE_ENV=development VITE_WATCH_MODE=true vite build --config config/vite/vite.config.firefox.js --watch",
    "dev:chrome": "cross-env NODE_ENV=development vite build --config config/vite/vite.config.chrome.js",
    "dev:firefox": "cross-env NODE_ENV=development vite build --config config/vite/vite.config.firefox.js",
    "dev:android": "node scripts/dev/android-runner.mjs --build",
    "watch:android": "node scripts/dev/android-runner.mjs",
    "lint": "eslint --config eslint.config.js",
    "lint:styles": "stylelint \"src/assets/styles/**/*.{css,scss}\"",
    "lint:styles:fix": "stylelint \"src/assets/styles/**/*.{css,scss}\" --fix",
    "format": "prettier --write src/**/*.js",
    "validate": "node scripts/validate/validate-all.mjs",
    "validate:chrome": "node scripts/validate/validate-chrome.mjs",
    "validate:firefox": "node scripts/validate/validate-firefox.mjs",
    "publish": "pnpm run build && pnpm run validate && pnpm run source",
    "pre-submit": "pnpm run lint && pnpm run lint:styles && pnpm run build",
    "source": "node scripts/dev/create-source-zip.mjs",
    "setup": "node scripts/setup/setup.cjs",
    "setup:chrome-validator": "pnpm add -D web-ext",
    "i18n:sync": "node scripts/localization/sync-i18n.cjs",
    "i18n:sync:fix": "node scripts/localization/sync-i18n.cjs --fix",
    "i18n:check": "node scripts/localization/check-i18n.cjs",
    "i18n:check:fix": "node scripts/localization/check-i18n.cjs --remove",
    "i18n:purge": "node scripts/localization/purge-notes.cjs",
    "analyze": "node scripts/dev/analyze-bundles.js",
    "perf:monitor": "node scripts/dev/performance-monitor.js"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/eslint-parser": "^7.27.1",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/preset-env": "^7.26.9",
    "@eslint/js": "^9.31.0",

    "@rollup/plugin-babel": "^6.0.4",
    "@vitejs/plugin-vue": "^6.0.0",

    "addons-linter": "^7.18.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.4.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-no-unsanitized": "^4.1.2",
    "eslint-plugin-vue": "^9.27.0",
    "fs-extra": "^11.3.0",
    "globals": "^16.3.0",


    "postcss": "^8.5.3",
    "postcss-html": "^1.7.0",
    "postcss-preset-env": "^10.2.4",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.1",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "sass": "^1.89.2",
    "sass-embedded": "^1.89.2",
    "stylelint": "^16.15.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-scss": "^6.10.0",
    "vite": "^7.0.5",
    "vite-plugin-web-extension": "^4.4.5",

    "vue-eslint-parser": "^9.4.3",
    "vue-i18n": "^11.1.11",
    "web-ext": "^8.9.0"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@vueuse/core": "^13.5.0",
    "archiver": "^7.0.1",
    "chalk": "^5.4.1",
    "core-js": "^3.41.0",
    "deepl-node": "^1.24.0",
    "dompurify": "^3.2.6",
    "domtranslator": "^1.3.1",
    "glob": "^11.0.1",
    "marked": "^16.1.1",
    "pinia": "^3.0.3",
    "regenerator-runtime": "^0.14.1",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "vue-sonner": "^2.0.8",
    "webextension-polyfill": "^0.12.0",
    "xss": "^1.0.15"
  },
  "packageManager": "pnpm@10.27.0"
}
